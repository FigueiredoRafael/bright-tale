{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(*)",
      "WebFetch",
      "WebSearch",
      "mcp__linear__*",
      "NotebookEdit",
      "TodoWrite"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git checkout --:*)",
      "Bash(git checkout .:*)",
      "Bash(git clean:*)",
      "Bash(git restore .:*)",
      "Bash(git stash:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit --no-gpg-sign:*)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(cat *.env*)",
      "Bash(less *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(cat .env*)",
      "Bash(less .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Write(.env.prod)",
      "Write(.env.staging)",
      "Write(.env.preview)",
      "Write(.env.development)",
      "Write(.env.dev)",
      "Write(.env.test)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.production)",
      "Write(**/.env.prod)",
      "Write(**/.env.staging)",
      "Write(**/.env.preview)",
      "Write(**/.env.development)",
      "Write(**/.env.dev)",
      "Write(**/.env.test)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Edit(.env.prod)",
      "Edit(.env.staging)",
      "Edit(.env.preview)",
      "Edit(.env.development)",
      "Edit(.env.dev)",
      "Edit(.env.test)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.production)",
      "Edit(**/.env.prod)",
      "Edit(**/.env.staging)",
      "Edit(**/.env.preview)",
      "Edit(**/.env.development)",
      "Edit(**/.env.dev)",
      "Edit(**/.env.test)",
      "Write(**/.claude/security/.prod-auth)",
      "Edit(**/.claude/security/.prod-auth)",
      "Write(**/*.pem)",
      "Write(**/*_rsa)",
      "Write(**/*_rsa.pub)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/anti-leak.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "typecheck",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit --pretty 2>&1 | head -20"
          }
        ]
      }
    ]
  }
}
