{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(*)",
      "WebFetch",
      "WebSearch",
      "mcp__linear__*",
      "NotebookEdit",
      "TodoWrite"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git checkout --:*)",
      "Bash(git checkout .:*)",
      "Bash(git clean:*)",
      "Bash(git restore .:*)",
      "Bash(git stash:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "typecheck",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit --pretty 2>&1 | head -20"
          }
        ]
      }
    ]
  }
}
