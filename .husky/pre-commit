#!/usr/bin/env bash
# Pre-commit: typecheck + lint to catch build-breaking issues before push.
# Tests and full builds are left to CI — keeping this hook fast reduces --no-verify temptation.

set -e

echo "→ Typecheck all workspaces..."
npm run typecheck

echo "→ Lint staged files..."
npx lint-staged

echo "✓ Pre-commit passed."
