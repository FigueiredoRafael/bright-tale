#!/usr/bin/env bash
# Pre-commit: build shared → typecheck → lint.
#
# "Build shared first" mirrors the Vercel build pipeline (build.sh compiles
# packages/shared to dist before the API is type-checked). Without this step,
# Zod inference differences between local and Vercel can let broken types slip
# through locally and only blow up in the Vercel build.
#
# Tests and full app builds are left to GitHub Actions — keeping this hook
# fast to reduce --no-verify temptation.

set -e

# Use nvm-managed node/npm if available (system npm may be outdated/broken)
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
# shellcheck source=/dev/null
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" --no-use
[ -f .nvmrc ] && nvm use --silent 2>/dev/null || true

echo "→ Building shared package (Vercel parity)..."
npm run build -w packages/shared

echo "→ Typecheck all workspaces..."
npm run typecheck

echo "→ Lint staged files..."
npx lint-staged

echo "✓ Pre-commit passed."
