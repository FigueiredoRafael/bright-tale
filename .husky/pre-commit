#!/usr/bin/env bash
# Pre-commit: runs typecheck, lint, and production builds for all workspaces
# to catch issues that would fail on Vercel deploy.

set -e

echo "→ Typecheck all workspaces..."
npm run typecheck

echo "→ Lint all workspaces..."
npm run lint

echo "→ Build all workspaces (same as Vercel)..."
npm run build --workspaces --if-present

echo "✓ Pre-commit passed — safe to push to Vercel."
