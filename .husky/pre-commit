#!/usr/bin/env bash
# Pre-commit: typecheck + lint to catch build-breaking issues before push.
# Tests and full builds are left to CI — keeping this hook fast reduces --no-verify temptation.

set -e

# Git hooks don't inherit the interactive shell's nvm env — source it explicitly.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
# shellcheck source=/dev/null
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" --no-use
[ -f ".nvmrc" ] && nvm use --silent 2>/dev/null || true

echo "→ Typecheck all workspaces..."
npm run typecheck

echo "→ Lint staged files..."
npx lint-staged

echo "✓ Pre-commit passed."
