{
  "name": "bright-tale",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n app,api,web,docs,inngest,ollama -c blue,green,cyan,yellow,magenta,gray \"npm:dev:app\" \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:docs\" \"npm:dev:inngest\" \"npm:dev:ollama\"",
    "dev:app": "npm run dev --workspace=@brighttale/app",
    "dev:api": "npm run dev --workspace=@brighttale/api",
    "dev:web": "npm run dev --workspace=@brighttale/web",
    "dev:docs": "npm run dev --workspace=@brighttale/docs-site",
    "dev:inngest": "npx inngest-cli@latest dev --no-discovery -u http://localhost:3001/inngest",
    "dev:ollama": "ollama serve 2>/dev/null || echo '[ollama] skipped — install with: brew install ollama (mac) or curl -fsSL https://ollama.com/install.sh | sh (linux)'",
    "build": "npm run build --workspaces --if-present",
    "build:app": "npm run build --workspace=@brighttale/app",
    "build:api": "npm run build --workspace=@brighttale/api",
    "build:web": "npm run build --workspace=@brighttale/web",
    "build:shared": "npm run build --workspace=@brighttale/shared",
    "test": "npm run test --workspaces --if-present",
    "test:app": "npm run test --workspace=@brighttale/app",
    "test:api": "npm run test --workspace=@brighttale/api",
    "test:shared": "npm run test --workspace=@brighttale/shared",
    "smoke:affiliate": "tsx scripts/smoke-affiliate.ts",
    "test:smoke:unit": "vitest run --config vitest.smoke.config.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:link:dev": "echo '[DEV] fxwykfyiicalcgbxslng' && bash scripts/db-with-token.sh link --project-ref fxwykfyiicalcgbxslng",
    "db:link:prod": "echo '[PROD] fxwykfyiicalcgbxslng' && bash scripts/db-with-token.sh link --project-ref fxwykfyiicalcgbxslng",
    "db:push:dev": "npm run db:link:dev && bash scripts/db-with-token.sh db push",
    "db:push:prod": "npm run db:link:prod && bash scripts/db-push-prod.sh",
    "db:types": "bash scripts/db-with-token.sh gen types typescript --project-id fxwykfyiicalcgbxslng > packages/shared/src/types/database.ts",
    "db:seed": "tsx scripts/generate-seed.ts && supabase db reset",
    "db:which": "bash scripts/db-which.sh",
    "email:start": "docker compose -f apps/api/docker-compose.dev.yml up -d",
    "email:stop": "docker compose -f apps/api/docker-compose.dev.yml down",
    "email:ui": "open http://localhost:8025",
    "generate:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "prepare": "[ -x node_modules/.bin/husky ] && husky || true"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "supabase": "^2.45.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "apps/app/**/*.{ts,tsx}": "eslint -c apps/app/eslint.config.mjs --no-warn-ignored --max-warnings 0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "zod": "^3.25.76",
    "@tn-figueiredo/auth": {
      "zod": "^3.25.76"
    },
    "@tn-figueiredo/auth-fastify": {
      "zod": "^3.25.76"
    }
  },
  "dependencies": {
    "@tailwindcss/typography": "0.5.19"
  }
}