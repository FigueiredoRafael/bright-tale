{
  "name": "bright-tale",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n app,api -c blue,green \"npm:dev:app\" \"npm:dev:api\"",
    "dev:app": "npm run dev --workspace=@brighttale/app",
    "dev:api": "npm run dev --workspace=@brighttale/api",
    "dev:web": "npm run dev --workspace=@brighttale/web",
    "build": "npm run build --workspaces --if-present",
    "build:app": "npm run build --workspace=@brighttale/app",
    "build:api": "npm run build --workspace=@brighttale/api",
    "build:web": "npm run build --workspace=@brighttale/web",
    "build:shared": "npm run build --workspace=@brighttale/shared",
    "test": "npm run test --workspaces --if-present",
    "test:app": "npm run test --workspace=@brighttale/app",
    "test:api": "npm run test --workspace=@brighttale/api",
    "test:shared": "npm run test --workspace=@brighttale/shared",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:link:dev": "echo '[DEV] fxwykfyiicalcgbxslng' && bash scripts/db-with-token.sh link --project-ref fxwykfyiicalcgbxslng",
    "db:link:prod": "echo '[PROD] fxwykfyiicalcgbxslng' && bash scripts/db-with-token.sh link --project-ref fxwykfyiicalcgbxslng",
    "db:push:dev": "npm run db:link:dev && bash scripts/db-with-token.sh db push",
    "db:push:prod": "npm run db:link:prod && bash scripts/db-push-prod.sh",
    "db:types": "bash scripts/db-with-token.sh gen types typescript --project-id fxwykfyiicalcgbxslng > packages/shared/src/types/database.ts",
    "db:seed": "tsx scripts/generate-seed.ts && supabase db reset",
    "db:which": "bash scripts/db-which.sh",
    "generate:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "prepare": "[ -x node_modules/.bin/husky ] && husky || true"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "supabase": "^2.45.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "zod": "^3.25.76",
    "@tn-figueiredo/auth": {
      "zod": "^3.25.76"
    },
    "@tn-figueiredo/auth-fastify": {
      "zod": "^3.25.76"
    }
  }
}
