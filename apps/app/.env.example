# URL of apps/api (server-side only — used in next.config.ts rewrites)
API_URL=http://localhost:3001

# Shared secret with apps/api — generate with: npm run generate:secret
INTERNAL_API_KEY=replace-with-openssl-rand-hex-32

# Provisioned for future Supabase Auth (unused today)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me

# ─── Observability ───────────────────────────────────────────────────────
# PostHog — client-side analytics (posthog.com, free 1M events/mo)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Axiom — logs + web vitals (axiom.co, free 500 GB/mo)
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=brighttale-app

# ─── Affiliate (Phase 2B) ──────────────────────────────────────────────
# Marketing-site origin for affiliate referral links. When
# window.location.origin does not start with "app.", the referral-link
# component falls back to this value (localhost:3002 in dev,
# https://brighttale.io in prod). Client-readable (NEXT_PUBLIC_).
# NEXT_PUBLIC_MARKETING_URL=https://brighttale.io

# ─── Search (Serper) ───────────────────────────────────────────────────
# Serper.dev API key for the research agent's `search_web` tool.
# Get one at https://serper.dev (free 2.5k queries/mo).
SEARCH_API_KEY=your-serper-api-key
