# API — rewrite target (Next.js rewrites /api/* → this URL)
API_URL=http://localhost:3001

# Shared secret with apps/api — generate with: npm run generate:secret
INTERNAL_API_KEY=

# Supabase — anon key only (safe to expose in browser)
# Local dev values below (same for everyone via npm run db:start)
# Staging/prod: replace with values from Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local-anon-key — run: supabase status>

# Stripe — publishable key (safe to expose in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Axiom — client-side logging
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=brighttale-app

# PostHog — client-side analytics (posthog.com, free 1M events/mo)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — error tracking
NEXT_PUBLIC_DEBUG_SENTRY=false
SENTRY_DSN=
