NEXT_PUBLIC_APP_URL=https://app.brighttale.io

# ─── Internal API (apps/api) ─────────────────────────────────────────────
# Local dev: http://localhost:3001  |  Production: https://api.brighttale.io
API_URL=http://localhost:3001
# Must match INTERNAL_API_KEY in apps/api/.env.local
INTERNAL_API_KEY=

# ─── Supabase ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Admin panel ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_SLUG=admin

# ─── Observability ───────────────────────────────────────────────────────
# PostHog — client-side analytics (posthog.com, free 1M events/mo)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Axiom — logs + web vitals (axiom.co, free 500 GB/mo)
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=brighttale-web
