PORT=3001
NODE_ENV=development

# Supabase — service role bypasses RLS; server-side ONLY
# Local dev values below (same for everyone via npm run db:start)
# Staging/prod: replace with values from Supabase dashboard
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key — run: supabase status>
SUPABASE_ANON_KEY=<local-anon-key — run: supabase status>

# Shared secret with apps/app — generate with: npm run generate:secret
INTERNAL_API_KEY=

# LLM providers (at least one required for AI features)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_KEY=

# YouTube Data API v3 — for YouTube Intelligence + reference analysis
# Create at: https://console.cloud.google.com/apis/credentials
# Quota: 10k units/day (search=100, videos=1, channels=1)
YOUTUBE_API_KEY=

# WordPress integration (optional)
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=

# Encryption (for AIProviderConfig stored keys)
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=

# Sentry — error tracking
SENTRY_DSN=

# Axiom — structured logging
AXIOM_TOKEN=
AXIOM_DATASET=brighttale-api

# PostHog — server-side analytics (posthog.com, free 1M events/mo)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Stripe — payments
# Test keys: dashboard.stripe.com/test/apikeys
# Live keys: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App origin — for Stripe redirect URLs and CORS
APP_ORIGIN=http://localhost:3000

# Email (SMTP via Resend or similar)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=noreply@brighttale.com.br
