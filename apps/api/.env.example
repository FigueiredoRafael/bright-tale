PORT=3001
NODE_ENV=development

# Supabase — service role bypasses RLS; server-side ONLY
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me

# Shared secret with apps/app — generate with: npm run generate:secret
INTERNAL_API_KEY=replace-with-openssl-rand-hex-32

# LLM providers (at least one required for AI features)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_KEY=

# WordPress integration (optional)
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=

# Encryption (for AIProviderConfig stored keys)
ENCRYPTION_SECRET=replace-with-64-char-hex

# ─── Stripe billing (F3) ──────────────────────────────────────────────────
# Create a Stripe account → Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_replace_me
# Dashboard → Developers → Webhooks → add endpoint $APP_API/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Price IDs — one per plan × cycle. Create Products + Prices in the Dashboard
# (docs/specs/pricing-plans.md has the plan spec). Each Price returns an id
# starting with "price_"; paste them here.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_CREATOR_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# Add-on packs (compra única de créditos) — F3-005
# Crie Products one-time no Stripe com prices pra 1k, 5k, 15k créditos
STRIPE_PRICE_ADDON_1K=
STRIPE_PRICE_ADDON_5K=
STRIPE_PRICE_ADDON_15K=

# Where Stripe redirects the user post-checkout
APP_ORIGIN=http://localhost:3000

# ─── Mercado Pago (F3-009, opcional) ─────────────────────────────────────
# Método de pagamento adicional pra BR (PIX/boleto). Stripe continua sendo
# o principal (cartão internacional + Apple Pay + etc). Setup pendente —
# ver apps/api/src/lib/billing/mercadopago.ts pro roadmap de integração.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ─── Phase 4 — Media (voice + video) ──────────────────────────────────────
# ElevenLabs (F4-001) — TTS premium multilíngue
ELEVENLABS_API_KEY=

# Stock footage (F4-005) — free tier generous
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Video render worker (F4-006/007) — URL do worker FFmpeg (Fly.io machine ou similar)
# Scaffold only; ver apps/api/src/lib/video/render.ts pra integração
VIDEO_WORKER_URL=

# ─── Phase 5 — Publishing ────────────────────────────────────────────────
# YouTube upload (F5-001) — GCP OAuth client (console.cloud.google.com)
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# ─── Email transport ──────────────────────────────────────────────────
# Choose provider: smtp (production via Resend — recommended),
# resend (legacy direct-API adapter), or none (silent no-op).
# See docs/security/EMAIL-CONFIG.md for full setup + rotation guide.
EMAIL_PROVIDER=smtp

# Resend via SMTP endpoint — production setup.
# Get the API key from https://resend.com/api-keys (permission=Sending,
# domain=brighttale.com.br). `SMTP_USER` is the literal string 'resend';
# `SMTP_PASS` is the Resend API key (starts with re_...).
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=noreply@brighttale.com.br

# Legacy Resend direct-API adapter (kept for backwards compat; NOT used
# when EMAIL_PROVIDER=smtp). Only set if flipping to EMAIL_PROVIDER=resend.
# RESEND_API_KEY=
# RESEND_FROM="BrightTale <noreply@brighttale.com.br>"

# MailHog fallback (local dev, no real send). Swap the SMTP_* block above
# for these values when running `docker compose up mailhog` locally.
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=dev@brighttale.local

# Integration tests only (MailHog preflight — defaults shown)
# MAILHOG_HOST=localhost
# MAILHOG_SMTP_PORT=1025
# MAILHOG_API_PORT=8025

# API public URL (OAuth callbacks, email links)
API_URL=http://localhost:3001

# ─── Observability ───────────────────────────────────────────────────────
# Axiom — structured logs (axiom.co, free 500 GB/mo)
# Use o API TOKEN (xaat-...) aqui — server-side only, nunca expor no browser.
AXIOM_TOKEN=
AXIOM_DATASET=brighttale-api

# PostHog — server-side analytics (posthog.com, free 1M events/mo)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ─── Phase 2A — Affiliate platform (@tn-figueiredo/affiliate@0.4.0) ──────
# All variables below are DEFERRABLE — code paths degrade silently when unset:
#   - Email is governed by EMAIL_PROVIDER (set to 'none' above to suppress
#     sends in environments without configured transport)
#   - Inngest cron 'affiliate-expire-referrals' simply does not register in
#     prod without keys; in dev `inngest-cli dev` works without them
# Set when activating the corresponding feature.

# Recipient for new-application admin notifications (default if unset)
AFFILIATE_ADMIN_EMAIL=admin@brighttale.com.br

# Inngest cloud auth — required ONLY for prod cron registration
# (dev: `npx inngest-cli@latest dev` works without these)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Affiliate fraud detection (Phase 2E) ─────────────────────────────
# Set to "true" to enable runtime fraud detection on signup attribution.
# Unset or "false" → AttributeSignupToAffiliateUseCase reverts to 2A behavior (no-op).
# FRAUD_DETECTION_ENABLED=true

# Thresholds (defaults from DEFAULT_FRAUD_CONFIG; tune post-launch from false-positive rate).
# FRAUD_AUTO_PAUSE_THRESHOLD=80
# FRAUD_NOTIFY_ADMIN_THRESHOLD=50

# ─── /ref/:code rate-limit (Phase 2E) ─────────────────────────────────
# @fastify/rate-limit config for the public redirect route. Applies per client IP.
# REF_RATE_LIMIT_MAX=30
# REF_RATE_LIMIT_WINDOW="1 minute"

# Serper web search (https://serper.dev) — required for research tool calling
SEARCH_API_KEY=
