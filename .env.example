# Root .env.local — consumed by Supabase CLI only
# Copy to .env.local and fill in the values

# Supabase CLI auth — required for remote commands (db:push:dev, db:types, db:diff)
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Google OAuth — consumed by supabase/config.toml via env() substitution
# Required for Google login to work in local dev (npm run db:start reads these)
# Find at: https://console.cloud.google.com/apis/credentials
# Add http://127.0.0.1:54321/auth/v1/callback as an authorized redirect URI in your OAuth app
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
