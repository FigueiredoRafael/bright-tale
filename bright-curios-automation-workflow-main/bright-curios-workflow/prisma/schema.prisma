// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ResearchArchive {
  id              String   @id @default(cuid())
  title           String
  theme           String
  research_content String  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  projects_count  Int      @default(0)
  winners_count   Int      @default(0)

  sources         ResearchSource[]
  projects        Project[]
}

model ResearchSource {
  id          String   @id @default(cuid())
  research_id String
  url         String
  title       String
  author      String?
  date        DateTime?
  created_at  DateTime @default(now())

  research    ResearchArchive @relation(fields: [research_id], references: [id], onDelete: Cascade)

  @@index([research_id])
}

model Project {
  id                  String   @id @default(cuid())
  title               String
  research_id         String?
  current_stage       String
  completed_stages    String[] @default([])
  auto_advance        Boolean  @default(true)
  status              String
  winner              Boolean  @default(false)
  video_style_config  String?  @db.Text // JSON: VideoStyleConfig — production style profile for this project
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  research      ResearchArchive? @relation(fields: [research_id], references: [id])
  stages        Stage[]

  @@index([research_id])
  @@index([status])
  @@index([current_stage])
}

model Stage {
  id            String   @id @default(cuid())
  project_id    String
  stage_type    String
  yaml_artifact String   @db.Text
  version       Int      @default(1)
  created_at    DateTime @default(now())

  project       Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  revisions     Revision[]

  @@index([project_id, stage_type])
}

model Revision {
  id            String   @id @default(cuid())
  stage_id      String
  yaml_artifact String   @db.Text
  version       Int
  created_at    DateTime @default(now())
  created_by    String?
  change_notes  String?  @db.Text

  stage         Stage    @relation(fields: [stage_id], references: [id], onDelete: Cascade)

  @@index([stage_id])
}

model IdeaArchive {
  id                String   @id @default(cuid())
  idea_id           String   @unique
  title             String
  core_tension      String   @db.Text
  target_audience   String
  verdict           String
  discovery_data    String   @db.Text
  
  // Library fields
  source_type       String   @default("brainstorm") // brainstorm | import | manual
  source_project_id String?
  tags              String[] @default([])
  is_public         Boolean  @default(true)
  usage_count       Int      @default(0)
  markdown_content  String?  @db.Text
  
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  @@index([verdict])
  @@index([source_type])
  @@index([is_public])
}

model Template {
  id                String   @id @default(cuid())
  name              String
  type              String
  config_json       String   @db.Text
  parent_template_id String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  parent            Template?  @relation("TemplateInheritance", fields: [parent_template_id], references: [id])
  children          Template[] @relation("TemplateInheritance")

  @@index([type])
}

model WordPressConfig {
  id              String   @id @default(cuid())
  site_url        String
  username        String
  password        String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model AIProviderConfig {
  id           String   @id @default(cuid())
  provider     String   // openai, anthropic, local
  api_key      String   // Encrypted with crypto.ts
  is_active    Boolean  @default(false)
  config_json  String?  @db.Text // Additional settings (model, temperature, etc.)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([provider])
  @@index([is_active])
}

model ImageGeneratorConfig {
  id           String   @id @default(cuid())
  provider     String   // "gemini"
  api_key      String   // Encrypted with crypto.ts (AES-256-GCM)
  model        String   // "imagen-3.0-generate-002" or "gemini-2.0-flash-exp-image-generation"
  is_active    Boolean  @default(false)
  config_json  String?  @db.Text // { numberOfImages, outputMimeType, aspectRatio }
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([is_active])
}

model Asset {
  id              String   @id @default(cuid())
  project_id      String?  // Nullable — standalone images in the global image bank
  asset_type      String
  source          String   // "unsplash" | "generated" | "upload"
  source_url      String?  // Nullable — local images may not have an external URL
  local_path      String?  // Filesystem path for generated images (relative to project root)
  prompt          String?  @db.Text // AI prompt used to generate this image
  role            String?  // "featured" | "section_1" | "thumbnail_option_1" | "chapter_1"
  content_type    String?  // "blog" | "video" | "shorts" | "podcast"
  content_id      String?  // blog_draft_id, video_draft_id, etc.
  alt_text        String?
  wordpress_id    Int?
  wordpress_url   String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([project_id])
  @@index([source])
  @@index([content_type])
  @@index([content_id])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  token        String   @unique
  purpose      String?  // e.g. "projects:bulk-create"
  request_hash String?  // optional dedupe / integrity check
  response     Json?    // stored response (e.g., created IDs)
  consumed     Boolean  @default(false)
  created_at   DateTime @default(now())
  expires_at   DateTime?

  @@index([token])
  @@index([created_at])
}

model AgentPrompt {
  id            String   @id @default(cuid())
  name          String   // Display name: "Discovery Agent", "Production Agent"
  slug          String   @unique // URL-friendly: "brainstorm", "production", "review"
  stage         String   // Maps to workflow stage: "brainstorm", "research", "production", "review"
  instructions  String   @db.Text // Full markdown instructions for AI
  input_schema  String?  @db.Text // YAML schema for input (optional)
  output_schema String?  @db.Text // YAML schema for expected output (optional)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([slug])
  @@index([stage])
}

// ═══════════════════════════════════════════════════════════════════════════
// CANONICAL CORE
// Intermediate narrative contract — generated by Agent 3a, consumed by format agents.
// ═══════════════════════════════════════════════════════════════════════════

model CanonicalCore {
  id                    String   @id @default(cuid())

  // Links
  idea_id               String
  project_id            String?

  // Core narrative contract (stored as JSON text)
  thesis                String   @db.Text
  argument_chain_json   String   @db.Text  // JSON: CanonicalCoreArgumentStep[]
  emotional_arc_json    String   @db.Text  // JSON: { opening_emotion, turning_point, closing_emotion }
  key_stats_json        String   @db.Text  // JSON: CanonicalCoreStat[]
  key_quotes_json       String?  @db.Text  // JSON: CanonicalCoreQuote[]
  affiliate_moment_json String?  @db.Text  // JSON: CanonicalCoreAffiliateMoment
  cta_subscribe         String?
  cta_comment_prompt    String?

  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@index([idea_id])
  @@index([project_id])
}

// ═══════════════════════════════════════════════════════════════════════════
// BLOG PRODUCTION
// Blog drafts library - stores blog posts with metadata for production workflow
// ═══════════════════════════════════════════════════════════════════════════

model BlogDraft {
  id                  String   @id @default(cuid())
  
  // Content
  title               String
  slug                String
  meta_description    String   @db.Text
  full_draft          String   @db.Text
  outline_json        String?  @db.Text  // JSON: Array of { h2, key_points, word_count_target }
  
  // SEO
  primary_keyword     String?
  secondary_keywords  String[] @default([])
  
  // Affiliate
  affiliate_placement String?  // intro | middle | conclusion
  affiliate_copy      String?  @db.Text
  affiliate_link      String?
  affiliate_rationale String?  @db.Text
  
  // Internal links
  internal_links_json String?  @db.Text  // JSON: Array of { topic, anchor_text }
  
  // Metadata
  word_count          Int      @default(0)
  status              String   @default("draft")  // draft | review | approved | published
  project_id          String?  // Link to project if created from workflow
  idea_id             String?  // Link to original idea
  
  // WordPress publishing
  wordpress_post_id   Int?
  wordpress_url       String?
  published_at        DateTime?
  
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([status])
  @@index([project_id])
  @@index([idea_id])
  @@index([slug])
}

// ═══════════════════════════════════════════════════════════════════════════
// VIDEO PRODUCTION
// Video script drafts - stores video scripts with metadata for production workflow
// ═══════════════════════════════════════════════════════════════════════════

model VideoDraft {
  id                      String   @id @default(cuid())

  // Content
  title                   String   // First title_option used as display title
  title_options           String[] @default([])
  thumbnail_json          String?  @db.Text  // JSON: { visual_concept, text_overlay, emotion, why_it_works }
  script_json             String?  @db.Text  // JSON: full VideoScript object (hook, problem, teaser, chapters[], affiliate_segment, outro)

  // Metadata
  total_duration_estimate String?
  word_count              Int      @default(0)  // Estimated spoken word count
  status                  String   @default("draft")  // draft | review | approved | published
  project_id              String?
  idea_id                 String?

  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@index([status])
  @@index([project_id])
  @@index([idea_id])
}

// ═══════════════════════════════════════════════════════════════════════════
// SHORTS PRODUCTION
// Shorts drafts - stores sets of 3 shorts with metadata
// ═══════════════════════════════════════════════════════════════════════════

model ShortsDraft {
  id              String   @id @default(cuid())

  // Content
  shorts_json     String   @db.Text  // JSON: ShortOutput[] array (includes sound_effects, background_music per short)

  // Metadata
  short_count     Int      @default(3)
  total_duration  String?
  status          String   @default("draft")  // draft | review | approved | published
  project_id      String?
  idea_id         String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([status])
  @@index([project_id])
  @@index([idea_id])
}

// ═══════════════════════════════════════════════════════════════════════════
// PODCAST PRODUCTION
// Podcast episode drafts - stores podcast outlines with metadata
// ═══════════════════════════════════════════════════════════════════════════

model PodcastDraft {
  id                  String   @id @default(cuid())

  // Content
  episode_title       String
  episode_description String   @db.Text
  intro_hook          String   @db.Text
  talking_points_json String   @db.Text  // JSON: Array of { point, notes }
  personal_angle      String   @db.Text
  guest_questions     String[] @default([])
  outro               String   @db.Text

  // Metadata
  duration_estimate   String?
  word_count          Int      @default(0)
  status              String   @default("draft")  // draft | review | approved | published
  project_id          String?
  idea_id             String?

  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([status])
  @@index([project_id])
  @@index([idea_id])
}
