# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bright_curios

# ─── GitHub Packages ─────────────────────────────────────────────────────────
# Required for npm install to pull @tn-figueiredo/* from GitHub Packages.
# Generate a classic PAT at https://github.com/settings/tokens with read:packages scope.
# Export in your shell profile: export NODE_AUTH_TOKEN=ghp_...
NODE_AUTH_TOKEN=ghp_your_token_here

# ─── AI Providers ────────────────────────────────────────────────────────────
# Set AI_PROVIDER to: openai | anthropic | mock (default: mock)
AI_PROVIDER=mock
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Image Generation ────────────────────────────────────────────────────────
# Set IMAGE_PROVIDER to: gemini | mock
IMAGE_PROVIDER=mock
GEMINI_API_KEY=AIza...
IMAGE_GENERATION_MODEL=gemini-2.5-flash-image

# ─── Assets ──────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte hex secret for encrypting stored API keys.
# Generate with: npm run generate:secret
ENCRYPTION_SECRET=your_64_char_hex_string

# ─── Feature flags ───────────────────────────────────────────────────────────
AI_ENABLED=true
ENABLE_BULK_LIMITS=false
MAX_BULK_CREATE=50
IDEMPOTENCY_TOKEN_TTL_SECONDS=3600
